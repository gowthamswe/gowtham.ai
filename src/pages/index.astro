---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import Icon from '../components/Icon.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE, ABOUT } from '../consts';
import timeline from '../data/timeline';
import { projects } from '../data/projects';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<BaseLayout>
  <div class="min-h-screen flex justify-center relative">
    <div class="max-w-[1400px] w-full flex flex-col md:flex-row relative z-10">
      <aside
        class="w-full md:w-[30vw] flex flex-col md:sticky md:top-0 md:self-start md:h-screen md:justify-between pt-[100px] pl-4 pb-6"
      >
        <div>
          <h1 class="glow text-[var(--fg-strong)] text-4xl">{SITE.title}</h1>
          <nav class="mt-6 flex gap-5 text-sm">
            <a href="/" class="text-white">Home</a>
            <a href="/blog" class="text-[var(--fg)] hover:text-white">Writing</a>
          </nav>
        </div>
        <SocialLinks />
      </aside>

      <main class="w-full md:w-[70vw] flex flex-col pb-10">
        <section class="pt-[100px] pl-4 md:pl-20 pr-4 pb-4">
          <h2 class="sr-only">About</h2>
          <p class="text-[var(--fg)] text-lg max-w-[70ch]">{ABOUT}</p>
        </section>

        {
          posts.length > 0 && (
            <section class="pt-12 pl-5 md:pl-20 pr-4 text-[var(--fg)]">
              <div class="flex items-baseline justify-between mb-4 max-w-[70ch]">
                <h2 class="text-xl font-bold">Writing</h2>
                <a href="/blog" class="text-sm underline hover:text-white inline-flex items-center gap-1">
                  All posts <Icon name="arrow-right" size={14} />
                </a>
              </div>
              {posts.map((post) => (
                <a href={`/blog/${post.id}/`} class="flex mb-5 card max-w-[70ch] hover:no-underline">
                  <div class="flex flex-col">
                    <span class="font-bold text-[var(--fg-strong)]">{post.data.title}</span>
                    <span class="text-sm text-[var(--fg-muted)] mt-1">
                      <FormattedDate date={post.data.pubDate} />
                    </span>
                    <span class="mt-2">{post.data.description}</span>
                  </div>
                </a>
              ))}
            </section>
          )
        }

        <section class="pt-12 pl-5 md:pl-20 pr-4 text-[var(--fg)]">
          <h2 class="text-xl font-bold mb-4">Projects</h2>
          {
            projects.map((project) => (
              <div class="flex mb-5 card max-w-[70ch]">
                <div class="flex flex-col">
                  <span class="font-bold">
                    {project.name} <span class="ml-2">({project.year})</span>
                  </span>
                  <span class="mt-2">{project.description}</span>
                  <div class="flex flex-wrap mt-2 items-center">
                    {project.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                    {project.links.map((link) => (
                      <a
                        href={link.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="ml-2 text-sm underline hover:text-white"
                      >
                        {link.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ))
          }
        </section>

        <section class="pt-12 pl-5 md:pl-20 pr-4 text-[var(--fg)]">
          <h2 class="text-xl font-bold mb-4">Timeline</h2>
          {
            timeline.map((entry) => (
              <div class="flex mb-5 card max-w-[70ch]">
                <div class="flex flex-col">
                  <span class="font-bold">
                    {entry.title} <span class="ml-2">({entry.year})</span>
                  </span>
                  {entry.description && <span class="mt-2">{entry.description}</span>}
                  {entry.tags && entry.tags.length > 0 && (
                    <div class="flex flex-wrap mt-2">
                      {entry.tags.map((tag) => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            ))
          }
        </section>
      </main>
    </div>
  </div>
</BaseLayout>
